# CareConnect Production Environment Template
# Copy this file to .env.production before running:
# docker compose --env-file .env.production -f docker-compose.prod.yml up -d

NODE_ENV=production
TZ=Asia/Bangkok
HTTP_PORT=80

POSTGRES_DB=careconnect
POSTGRES_USER=careconnect
POSTGRES_PASSWORD=change_me_strong

CORS_ORIGIN=https://careconnect.example.com
FRONTEND_URL=https://careconnect.example.com
BACKEND_URL=https://careconnect.example.com

JWT_SECRET=change_me_strong
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
WEBHOOK_SECRET=change_me_strong

PAYMENT_PROVIDER=stripe
STRIPE_PUBLISHABLE_KEY=pk_live_xxx
STRIPE_SECRET_KEY=sk_live_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_ACCOUNT_ID=acct_xxx

SMS_PROVIDER=smsok
SMSOK_API_URL=https://api.smsok.co/s
SMSOK_API_KEY=change_me
SMSOK_API_SECRET=change_me
SMSOK_SENDER=CareConnect

EMAIL_PROVIDER=smtp
EMAIL_FROM=noreply@careconnect.example.com
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=change_me
SMTP_PASS=change_me

PUSH_PROVIDER=mock
KYC_PROVIDER=mock
BANK_TRANSFER_PROVIDER=mock

ADMIN_EMAIL=admin@careconnect.example.com
ADMIN_PASSWORD=change_me_strong

GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

UPLOAD_DIR=/app/uploads
MAX_FILE_SIZE_MB=10

VITE_API_URL=
VITE_API_BASE_URL=
VITE_SOCKET_URL=
VITE_GOOGLE_MAPS_API_KEY=
VITE_VAPID_PUBLIC_KEY=
