NODE_ENV=development
TZ=Asia/Bangkok
HTTP_PORT=8080
MOCK_PROVIDER_PORT=4001

POSTGRES_DB=careconnect
POSTGRES_USER=careconnect
POSTGRES_PASSWORD=careconnect_quickstart_password

CORS_ORIGIN=http://localhost:8080
FRONTEND_URL=http://localhost:8080
BACKEND_URL=http://localhost:8080
MOCK_PROVIDER_PUBLIC_URL=http://localhost:4001

JWT_SECRET=careconnect_quickstart_jwt_secret
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d
WEBHOOK_SECRET=careconnect_quickstart_webhook_secret

PAYMENT_PROVIDER=mock
SMS_PROVIDER=mock
EMAIL_PROVIDER=mock
EMAIL_FROM=noreply@careconnect.local
PUSH_PROVIDER=mock
KYC_PROVIDER=mock
BANK_TRANSFER_PROVIDER=mock

ADMIN_EMAIL=admin@careconnect.local
ADMIN_PASSWORD=Admin1234!
SEED_MOCK_CAREGIVERS=true
SEED_MOCK_JOBS=true

MOCK_PAYMENT_AUTO_SUCCESS=true
MOCK_PAYMENT_SUCCESS_DELAY_MS=3000
MOCK_SMS_OTP_CODE=123456
MOCK_EMAIL_OTP_CODE=123456

MAX_FILE_SIZE_MB=10

VITE_API_URL=
VITE_API_BASE_URL=
VITE_SOCKET_URL=
VITE_GOOGLE_MAPS_API_KEY=
VITE_VAPID_PUBLIC_KEY=

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
