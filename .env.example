# CareConnect Development Environment Template
# Copy this file to .env for local development.
# Optional overlays such as .env.development are loaded after .env when present.

NODE_ENV=development
TZ=Asia/Bangkok

PORT=3000
CORS_ORIGIN=http://localhost:5173

DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=careconnect
DATABASE_USER=careconnect
DATABASE_PASSWORD=careconnect_dev_password

JWT_SECRET=careconnect_jwt_secret_dev_only
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d
WEBHOOK_SECRET=careconnect_webhook_secret_dev

UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=10

FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:3000

ADMIN_EMAIL=admin@careconnect.com
ADMIN_PASSWORD=Admin1234!

MOCK_PROVIDER_BASE_URL=http://localhost:4000
WEBHOOK_BASE_URL=http://localhost:3000
BACKEND_WEBHOOK_URL=http://localhost:3000/api/webhooks
MOCK_PAYMENT_CALLBACK_URL=http://localhost:3000/api/webhooks/payment

PAYMENT_PROVIDER=mock
SMS_PROVIDER=mock
EMAIL_PROVIDER=mock
EMAIL_FROM=noreply@careconnect.local
PUSH_PROVIDER=mock
KYC_PROVIDER=mock
BANK_TRANSFER_PROVIDER=mock

# If you switch a provider away from mock in development, missing credentials
# will log console warnings and the backend will fall back to mock automatically.
STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_ACCOUNT_ID=

SMSOK_API_URL=https://api.smsok.co/s
SMSOK_API_KEY=
SMSOK_API_SECRET=
SMSOK_SENDER=CareConnect

SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

VITE_API_TARGET=http://localhost:3000
VITE_API_URL=
VITE_API_BASE_URL=
VITE_SOCKET_URL=
VITE_GOOGLE_MAPS_API_KEY=
VITE_VAPID_PUBLIC_KEY=
VITE_DEV_PORT=5173
VITE_PUBLIC_HOST=
VITE_PUBLIC_PROTOCOL=
VITE_PUBLIC_PORT=
VITE_PUBLIC_HMR_PORT=
VITE_USE_POLLING=false
VITE_POLL_INTERVAL=300

MOCK_PAYMENT_AUTO_SUCCESS=true
MOCK_PAYMENT_SUCCESS_DELAY_MS=3000
MOCK_SMS_OTP_CODE=123456
MOCK_EMAIL_OTP_CODE=123456
MOCK_KYC_AUTO_APPROVE=true
MOCK_KYC_APPROVAL_DELAY_MS=5000

SEED_MOCK_CAREGIVERS=true
SEED_MOCK_JOBS=true

PGADMIN_DEFAULT_EMAIL=admin@careconnect.local
PGADMIN_DEFAULT_PASSWORD=admin